    {
      "type": "text",
      "id": "lbl_legend_body",
      "x": 1280, "y": 354,
      "width": 320, "height": 200,
      "text": "Solid arrow = forward transition\nDashed border = non-terminal pause\nThick stroke = terminal state\nDashed arrow = re-open path\n\ncreate_sweep(transitions={...})\n      validates DAG.\n\nNone (default) = unconstrained\n— consumer's policy.",
      "originalText": "Solid arrow = forward transition\nDashed border = non-terminal pause\nThick stroke = terminal state\nDashed arrow = re-open path\n\ncreate_sweep(transitions={...})\n      validates DAG.\n\nNone (default) = unconstrained\n— consumer's policy.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
